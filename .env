# ══════════════════════════════════════════════════════════════════════
# TicketForge Pro — Public defaults (safe to commit to GitHub)
# Real secrets go in .env.local which is gitignored.
# On Vercel: set ALL variables in the Vercel dashboard.
# ══════════════════════════════════════════════════════════════════════

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase — placeholders only, real values in .env.local
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
# Service role key — server-only, NEVER exposed to client
# Found in Supabase dashboard → Project Settings → API → service_role
# Required for: role promotion, staff invite creation, Supabase Admin API calls
SUPABASE_SERVICE_ROLE_KEY=""

# EmailJS — staff invite email template (optional: separate template for staff invites)
# EMAILJS_STAFF_TEMPLATE_ID=""   # if blank, falls back to NEXT_PUBLIC_EMAILJS_TEMPLATE_ID

# Google OAuth — set to "true" in .env.local after configuring
NEXT_PUBLIC_GOOGLE_ENABLED="false"

# Platform settings
OVERRIDE_PIN="1234"
PLATFORM_FEE_PERCENT="2.5"
DEMO_EMAIL="demo@ticketforge.app"
NEXT_PUBLIC_DEMO_EMAIL="demo@ticketforge.app"

# M-Pesa sandbox defaults
MPESA_ENV="sandbox"
MPESA_SHORTCODE="174379"
MPESA_CALLBACK_URL="http://localhost:3000/api/mpesa/callback"

# Resend — transactional email (staff invites + ticket delivery)
# Get your free API key at resend.com (3,000 emails/month free)
# Sandbox: uses onboarding@resend.dev as sender (no domain needed)
# Production: set RESEND_FROM_EMAIL=noreply@yourdomain.com after domain verification
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"
RESEND_FROM_NAME="TicketForge"
