# ══════════════════════════════════════════════════════════════════════
# TicketForge Pro — Environment Variables
# Copy this file to .env.local and fill in your values
# ══════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────
# Option A: Local SQLite (development, no setup needed)
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# Option B: Supabase Postgres (staging + production)
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres"
# Note: Set both DATABASE_URL (pooled via PgBouncer) and DIRECT_URL (for migrations)

# ── Supabase Setup Guide ──────────────────────────────────────────────
# 1. Go to supabase.com → New project → choose a region close to Kenya (eu-west or me-south-1)
# 2. Project Settings → Database → Connection string → copy "URI"
# 3. Paste as DATABASE_URL above (replace [password] with your db password)
# 4. Run: npx prisma db push   (pushes your schema to Supabase Postgres)
# 5. Run: npm run db:seed      (optional: seeds demo data)
# 6. Authentication → Providers → Enable Email and Google
# 7. Authentication → URL Configuration → add your site URL and redirect URLs

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ── NextAuth ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-32-char-secret-here"
AUTH_URL="https://yourdomain.com"

# Google OAuth (console.cloud.google.com → Credentials → OAuth 2.0)
# Add authorised redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Demo account ──────────────────────────────────────────────────────
DEMO_EMAIL="demo@ticketforge.app"
DEMO_PASSWORD="TicketForgeDemo2025"
NEXT_PUBLIC_DEMO_EMAIL="demo@ticketforge.app"

# ── M-Pesa · Daraja API ───────────────────────────────────────────────
# developer.safaricom.co.ke → Create App → Enable M-Pesa Express
MPESA_ENV="sandbox"
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""
MPESA_CALLBACK_URL="https://yourdomain.com/api/mpesa/callback"

# ── EmailJS ───────────────────────────────────────────────────────────
# emailjs.com → free 200 emails/month
NEXT_PUBLIC_EMAILJS_SERVICE_ID=""
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=""
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=""

# ── Gate scanner ──────────────────────────────────────────────────────
OVERRIDE_PIN=""
PLATFORM_FEE_PERCENT=""
