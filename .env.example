# ══════════════════════════════════════════════════════════════════════
# TicketForge — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is already in .gitignore.
#
# Required vars are marked  ✦  — the app will not start without them.
# Optional vars are marked  ◦  — they enable extra features when set.
# ══════════════════════════════════════════════════════════════════════


# ── App ────────────────────────────────────────────────────────────────
# ✦ Your production domain (used in email links and ticket download URLs)
NEXT_PUBLIC_APP_URL="https://yourdomain.com"


# ── Supabase ───────────────────────────────────────────────────────────
# ✦ Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# ✦ Project Settings → API → anon (public) key
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ✦ Project Settings → API → service_role (secret) key — NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Setup:
#   1. supabase.com → New project → region close to your users
#   2. Authentication → Providers → enable Email (and Google if needed)
#   3. Authentication → URL Configuration → add:
#        Site URL:             https://yourdomain.com
#        Redirect URL:         https://yourdomain.com/auth/callback
#   4. Apply DB migrations (see Database section below)


# ── Database (Supabase Postgres) ───────────────────────────────────────
# ✦ Project Settings → Database → Connection string → "Transaction" mode (port 6543)
#   Add ?pgbouncer=true&connection_limit=1 for PgBouncer compatibility
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx-xxx-x.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ✦ Project Settings → Database → Connection string → "Session" mode (port 5432)
#   Used for Prisma migrations — bypasses PgBouncer
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx-xxx-x.pooler.supabase.com:5432/postgres"

# After filling in the above, apply the schema:
#   npm run db:push          # push schema to Supabase (first deploy)
#   npm run db:migrate       # run migrations (subsequent changes)


# ── Resend (transactional email) ───────────────────────────────────────
# ✦ resend.com → API Keys → Create API Key
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ◦ Verified sender address (resend.com → Domains → verify your domain first)
#   Falls back to onboarding@resend.dev (Resend sandbox) if not set —
#   fine for testing but sandbox emails may land in spam.
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ◦ Display name shown in the From: field
RESEND_FROM_NAME="TicketForge"


# ── Google OAuth ───────────────────────────────────────────────────────
# ◦ console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
#   Authorised redirect URI: https://xxxxxxxxxxxx.supabase.co/auth/v1/callback
# Enable in Supabase: Authentication → Providers → Google
NEXT_PUBLIC_GOOGLE_ENABLED="false"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""


# ── M-Pesa / Daraja API ────────────────────────────────────────────────
# ◦ developer.safaricom.co.ke → Apps → Create App → Enable M-Pesa Express (STK Push)
#   Set to "production" and use live credentials when going live.
MPESA_ENV="sandbox"
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""

# ✦ Must be a publicly reachable HTTPS URL — Safaricom POSTs payment results here.
#   For local dev use ngrok: ngrok http 3000 → copy the https URL
MPESA_CALLBACK_URL="https://yourdomain.com/api/mpesa/callback"


# ── Demo account ───────────────────────────────────────────────────────
# ◦ Pre-seeded demo organiser account (created by npm run admin:seed)
NEXT_PUBLIC_DEMO_EMAIL="demo@yourdomain.com"
DEMO_EMAIL="demo@yourdomain.com"
DEMO_PASSWORD="change-me-in-production"


# ── Platform settings ──────────────────────────────────────────────────
# ◦ Platform fee percentage charged on paid tickets (e.g. "5" = 5%)
PLATFORM_FEE_PERCENT="0"
